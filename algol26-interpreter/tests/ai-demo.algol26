proc sigmoid(x: real) => real = (1.0+exp(-x))^(-1);
proc forward(input: array[2] of real, w: array[2] of real, b: real) => real = sigmoid(w[1]*input[1] + w[2]*input[2] + b);
begin
  var inp: array[2] of real := [0.5, 0.3];
  var weights: array[2] of real := [0.8, 1.2];
  var bias: real := 0.1;
  var output: real := forward(inp, weights, bias);
  println("Neural network output: ", output);
end
